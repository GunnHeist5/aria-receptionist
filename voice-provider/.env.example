# Which VoiceProvider implementation the system uses.
#   mock    → MockVoiceProvider (in-memory, no external calls — default for dev/test)
#   trillet → TrilletVoiceProvider (real API; requires TRILLET_API_KEY below)
VOICE_PROVIDER=mock

# ── Trillet (required only when VOICE_PROVIDER=trillet) ─────────────────────
TRILLET_API_KEY=
# Your Trillet workspace ID.  Run `node scripts/trillet-probe.js` to confirm.
TRILLET_WORKSPACE_ID=
TRILLET_API_BASE_URL=https://api.trillet.ai/v1

# ── Failure simulation (MockVoiceProvider only) ──────────────────────────────
# Comma-separated list of method names that should throw on every call.
# Used to exercise the onboarding pipeline's error-handling and resumability
# without modifying any code.
#
# Example:  MOCK_FAIL_METHODS=provisionNumber,applyContentPack
# Leave empty (or unset) for happy-path behaviour.
MOCK_FAIL_METHODS=
