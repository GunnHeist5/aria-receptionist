# Sandbox environment for overnight build-and-test runs. DUMMY VALUES ONLY.
# The overnight runner copies this into the isolated worktree as `.env`, so any
# code/tests that read process.env get harmless placeholders and cannot reach
# production systems. NEVER put real credentials in this file.
NODE_ENV=test
VOICE_PROVIDER=mock
DATABASE_URL=postgres://test:test@localhost:5432/test_does_not_exist
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
NEXT_PUBLIC_BASE_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=000000:dummy
TELEGRAM_OWNER_CHAT_ID=0
TELEGRAM_WEBHOOK_SECRET=dummy
TELEGRAM_BOT_USERNAME=dummy_bot
PANDADOC_API_KEY=dummy
PANDADOC_TEMPLATE_ID=dummy
PANDADOC_RECIPIENT_ROLE=Client
PANDADOC_COMPANY_ROLE=Justin
OPENAI_API_KEY=sk-dummy
ANTHROPIC_API_KEY=sk-ant-dummy
