# Voice provider — inherited by the onboarding pipeline from the voice-provider component.
# See ../voice-provider/.env.example for full options.
VOICE_PROVIDER=mock

# Phone number the operator uses to receive test calls during onboarding step 4.
# If not set, the run_test_call step skips gracefully (pipeline still completes).
# Use your own mobile number in dev; a dedicated QA line in prod.
TEST_CALL_NUMBER=
