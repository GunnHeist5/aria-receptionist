# Connection string for the Postgres spine.
# The orchestrator (key holder / cron runner) supplies the real value at runtime.
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_receptionist

# Optional: require TLS to the database (set to "true" for most managed Postgres,
# e.g. Supabase / RDS / Neon). Leave unset/false for a local dev server.
PGSSL=false
